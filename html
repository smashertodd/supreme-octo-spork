<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fix the Paragraph</title>

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- React 18 (UMD builds — no bundler needed) -->
  <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>

  <!-- Babel standalone — transpiles JSX at runtime -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f1f5f9;
      color: #0f172a;
    }
    body.theme-dark  { background: #020617; color: #e2e8f0; }
    body.theme-light { background: #f1f5f9; color: #0f172a; }

    /* Drag-and-drop tiles */
    .piece-tile {
      cursor: grab;
      user-select: none;
      transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
    }
    .piece-tile:active { cursor: grabbing; }
    .piece-tile.dragging { opacity: 0.4; transform: scale(0.97); }
    .piece-tile.drag-over { box-shadow: 0 0 0 3px #6366f1; }

    /* Drop zone */
    .drop-zone {
      min-height: 3rem;
      transition: background 0.15s, border-color 0.15s;
    }
    .drop-zone.active { background: #e0e7ff; border-color: #6366f1; }

    /* Focus ring — WCAG 2.1 AA */
    :focus-visible {
      outline: 3px solid #6366f1;
      outline-offset: 2px;
      border-radius: 4px;
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 9999;
      animation: slideUp 0.3s ease;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(1rem); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Tabs */
    .tab-btn { transition: background 0.15s, color 0.15s; }
    .tab-btn.active {
      background: #6366f1;
      color: #fff;
    }

    /* Scrollbar (Webkit) */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
  </style>
</head>
<body>
  <div id="root"></div>

  <!-- App logic — type="text/babel" tells Babel standalone to transpile -->
  <script type="text/babel" src="app.js" data-type="module"></script>
</body>
</html>
